            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/yield-tokens",
              "concepts/minting-and-redemption",
              "concepts/pricing-and-liquidity",
              "concepts/routing"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/explore-markets",
              "guides/create-yield-token",
              "guides/deposit-and-withdraw",
              "guides/fees"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/sdk",
              "integrations/aggregators",
              "integrations/wallets-and-vaults"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/supported-protocols",
              "reference/pool-registry",
              "reference/risk-model",
              "reference/program"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.overpass.money",
          "icon": "arrow-up-right"
        },
        {
          "anchor": "Symmetry",
          "href": "https://symmetry.fi",
          "icon": "building-2"
        }
      ]
    }
