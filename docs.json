{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Overpass",
  "colors": {
    "primary": "#347A00",
    "light": "#347A00",
    "dark": "#84FF00"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
